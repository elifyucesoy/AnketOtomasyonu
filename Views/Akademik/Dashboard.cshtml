@using AnketOtomasyonu.Models.Entities
@model IEnumerable<Survey>
@{
    ViewData["Title"] = "Akademik Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-mortarboard-fill me-2" style="color: #0dcaf0;"></i>Akademik Dashboard</h2>
    <span class="badge bg-su fs-6 px-3 py-2">@ViewBag.UserBirim</span>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0"><i class="bi bi-list-check me-2"></i>Biriminizdeki Aktif Anketler</h5>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-clipboard-x display-4 text-secondary mb-3"></i>
                <p>Biriminize ait aktif ve yayınlanmış bir anket bulunmamaktadır.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Anket Adı</th>
                            <th>Oluşturan</th>
                            <th>Oluşturulma Tarihi</th>
                            <th>Bitiş Tarihi</th>
                            <th>Roller</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">@s.Title</td>
                                <td><span class="badge bg-light text-dark border">@s.CreatedByName</span></td>
                                <td>@s.CreatedAt.ToShortDateString()</td>
                                <td>@(s.EndDate.HasValue ? s.EndDate.Value.ToShortDateString() : "-")</td>
                                <td>
                                    @if(s.TargetRoles == null) {
                                      <span class="badge bg-secondary">Herkes</span>
                                    } else {
                                        if (s.TargetRoles.Contains("Student")) { <span class="badge bg-primary">Öğrenci</span> }
                                        if (s.TargetRoles.Contains("Employee")) { <span class="badge bg-success">Personel</span> }
                                        if (s.TargetRoles.Contains("Admin")) { <span class="badge bg-dark">Admin</span> }
                                    }
                                    @if(s.IsAnonymous)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-incognito me-1"></i>Anonim</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Home" asp-action="Results" asp-route-id="@s.Id" class="btn btn-sm" style="background-color: #0dcaf0; color: #1B2A4A; font-weight: 600;">
                                        <i class="bi bi-bar-chart-fill me-1"></i>Sonuçları Gör
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
