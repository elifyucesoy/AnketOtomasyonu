@{
    ViewData["Title"] = "DEV LOGIN";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>⚙️ Dev Login</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <style>
        body { background: #1a1a2e; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .card { border-radius: 12px; max-width: 480px; width: 100%; }
        .role-card { border: 2px solid #dee2e6; border-radius: 8px; padding: 14px 16px; cursor: pointer; transition: all .2s; }
        .role-card:hover { border-color: #6c757d; background: #f8f9fa; }
        input[type=radio]:checked + .role-card { border-color: #e94560; background: #fff5f7; }
    </style>
</head>
<body>
<div class="card shadow-lg">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
        <span><i class="bi bi-code-slash me-2"></i><strong>DEV LOGIN</strong></span>
        <span class="badge" style="background:#e94560;font-size:.75rem;padding:3px 10px;border-radius:20px">DEVELOPMENT ONLY</span>
    </div>
    <div class="card-body p-4">
        <p class="text-muted small mb-4">
            Gerçek API çağrısı <strong>yapılmaz</strong>. Session elle kurulur.
            Sadece <code>ASPNETCORE_ENVIRONMENT=Development</code> ortamında çalışır.
        </p>

        <form method="post" asp-action="DevLogin" asp-controller="Auth">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label fw-semibold mb-3">Kullanıcı rolü seçin:</label>

                <div class="d-flex flex-column gap-2">

                    <label class="d-flex align-items-center gap-0">
                        <input type="radio" name="role" value="Admin" class="d-none" id="r_admin" checked />
                        <div class="role-card w-100" onclick="document.getElementById('r_admin').click()">
                            <span class="badge bg-danger me-2">Admin</span>
                            <strong>Admin (Personel + Yönetici)</strong>
                            <div class="text-muted small mt-1">
                                hasPermission=true · userTypeId=0 · Admin Paneli erişimi
                            </div>
                        </div>
                    </label>

                    <label class="d-flex align-items-center gap-0">
                        <input type="radio" name="role" value="Employee" class="d-none" id="r_employee" />
                        <div class="role-card w-100" onclick="document.getElementById('r_employee').click()">
                            <span class="badge bg-success me-2">Personel</span>
                            <strong>Employee (Personel)</strong>
                            <div class="text-muted small mt-1">
                                hasPermission=false · userTypeId=0 · ANKET_API_STUDENT erişimi
                            </div>
                        </div>
                    </label>

                    <label class="d-flex align-items-center gap-0">
                        <input type="radio" name="role" value="Student" class="d-none" id="r_student" />
                        <div class="role-card w-100" onclick="document.getElementById('r_student').click()">
                            <span class="badge bg-primary me-2">Öğrenci</span>
                            <strong>Student (Öğrenci)</strong>
                            <div class="text-muted small mt-1">
                                hasPermission=false · userTypeId=1 · ANKET_API_STUDENT erişimi
                            </div>
                        </div>
                    </label>

                </div>
            </div>

            <button type="submit" class="btn btn-danger w-100 fw-semibold">
                <i class="bi bi-box-arrow-in-right me-2"></i>Session Kur &amp; Devam Et
            </button>
        </form>
    </div>
    <div class="card-footer bg-light text-muted small py-2 px-4">
        <i class="bi bi-info-circle me-1"></i>
        <code>UserRole</code> = Admin / Employee / Student &nbsp;|&nbsp;
        <code>UserType</code> = Employee / Student &nbsp;|&nbsp;
        <code>UserTypeId</code> = 0 / 1
    </div>
</div>
<script>
    // Seçili radio'nun card'ını highlight et
    document.querySelectorAll('input[name=role]').forEach(function(radio) {
        radio.addEventListener('change', function() {
            document.querySelectorAll('.role-card').forEach(c => c.style.borderColor = '');
            if (this.checked) this.nextElementSibling.style.borderColor = '#e94560';
        });
    });
    document.getElementById('r_admin').dispatchEvent(new Event('change'));
</script>
</body>
</html>
