<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AnketOtomasyonu</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AnketOtomasyonu.styles.css" asp-append-version="true" />

    <style>
        :root {
            --su-dark: #3A3A3A;
            --su-yellow: #F9BC00;
        }

        body {
            font-family: 'Segoe UI',Tahoma,sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .navbar-su {
            background: var(--su-dark) !important;
        }

            .navbar-su .navbar-brand {
                color: var(--su-yellow) !important;
                font-weight: 700;
            }

            .navbar-su .nav-link {
                color: rgba(255,255,255,.85) !important;
                font-weight: 500;
            }

                .navbar-su .nav-link:hover {
                    color: var(--su-yellow) !important;
                }

        .btn-su {
            background: var(--su-yellow);
            color: var(--su-dark);
            font-weight: 600;
            border: none;
            border-radius: 25px;
            padding: 8px 24px;
        }

            .btn-su:hover {
                background: #E0AB00;
                color: var(--su-dark);
            }

        .footer-su {
            background: var(--su-dark);
            color: #999;
            padding: 20px 0;
            margin-top: auto;
        }

        main {
            flex: 1;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-su shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-clipboard2-data me-2"></i>AnketOtomasyonu
                </a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Menü">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @{
                    var _navRole     = Context.Session.GetString("UserRole");
                    var _navType     = Context.Session.GetString("UserType");
                    var _navLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("AccessToken"));
                    var _navName     = Context.Session.GetString("UserFullName");
                }
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i>Ana Sayfa
                            </a>
                        </li>

                        @if (_navLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SurveyResponse" asp-action="PublicSurveys">
                                    <i class="bi bi-list-check me-1"></i>Anketler
                                </a>
                            </li>
                        }

                        @if (_navRole == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-shield-lock me-1"></i>Admin Paneli
                                </a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">
                        @if (_navLoggedIn)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i>@_navName
                                    @* UserRole: "Admin" | "Employee" | "Student" *@
                                    @if (_navRole == "Admin")
                                    {
                                        <span class="badge bg-danger ms-1" style="font-size:0.65rem">Admin</span>
                                    }
                                    else if (_navRole == "Student")
                                    {
                                        <span class="badge bg-primary ms-1" style="font-size:0.65rem">Öğrenci</span>
                                    }
                                    else if (_navRole == "Employee")
                                    {
                                        <span class="badge bg-success ms-1" style="font-size:0.65rem">Personel</span>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-1"></i>Çıkış Yap
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Giriş Yap
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>


    <!-- CONTENT -->
    <div class="container py-4">
        <main role="main" class="pb-3">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()

        </main>
    </div>


    <!-- FOOTER -->
    <footer class="footer-su">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - AnketOtomasyonu
        </div>
    </footer>


    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
