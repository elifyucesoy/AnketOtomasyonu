<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AnketOtomasyonu</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AnketOtomasyonu.styles.css" asp-append-version="true" />

    <style>
        :root {
            --su-dark: #3A3A3A;
            --su-yellow: #F9BC00;
        }

        body {
            font-family: 'Segoe UI',Tahoma,sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .navbar-su {
            background: var(--su-dark) !important;
        }

            .navbar-su .navbar-brand {
                color: var(--su-yellow) !important;
                font-weight: 700;
            }

            .navbar-su .nav-link {
                color: rgba(255,255,255,.85) !important;
                font-weight: 500;
            }

                .navbar-su .nav-link:hover {
                    color: var(--su-yellow) !important;
                }

        .btn-su {
            background: var(--su-yellow);
            color: var(--su-dark);
            font-weight: 600;
            border: none;
            border-radius: 25px;
            padding: 8px 24px;
        }

            .btn-su:hover {
                background: #E0AB00;
                color: var(--su-dark);
            }

        .footer-su {
            background: var(--su-dark);
            color: #999;
            padding: 20px 0;
            margin-top: auto;
        }

        main {
            flex: 1;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <!-- 1) YÖNETİM LİNKİ — Cookie yerine Session -->
    @if (Context.Session.GetString("UserRole") == "Admin")
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                <i class="bi bi-speedometer2 me-1"></i>Yönetim
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Admin" asp-action="CreateSurvey">
                <i class="bi bi-plus-circle me-1"></i>Yeni Anket
            </a>
        </li>
    }

    <!-- 2) KULLANICI DROPDOWN — Session kontrolü -->
    @if (Context.Session.GetString("AccessToken") != null)
    {
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i>
                @(Context.Session.GetString("UserFullName") ?? "Kullanıcı")
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <span class="dropdown-item-text text-muted small">
                        <i class="bi bi-shield-check me-1"></i>
                        @(Context.Session.GetString("UserRole") ?? "")
                    </span>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <!-- 3) LOGOUT — form ile POST -->
                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item border-0 bg-transparent w-100 text-start">
                            <i class="bi bi-box-arrow-right me-1"></i>Çıkış Yap
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="btn btn-sm"
               style="border:2px solid #F9BC00;color:#F9BC00;border-radius:25px;padding:6px 20px;"
               asp-controller="Auth" asp-action="Login">
                <i class="bi bi-box-arrow-in-right me-1"></i>Giriş Yap
            </a>
        </li>
    }
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>


    <!-- CONTENT -->
    <div class="container py-4">
        <main role="main" class="pb-3">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()

        </main>
    </div>


    <!-- FOOTER -->
    <footer class="footer-su">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - AnketOtomasyonu
        </div>
    </footer>


    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
