<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SuperAdmin Paneli</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --sa-dark:   #0f172a;
            --sa-dark2:  #0a0f1e;
            --sa-purple: #7c3aed;
            --sa-purple2:#6d28d9;
            --sa-gold:   #f59e0b;
            --sa-light:  #f1f5f9;
        }

        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: var(--sa-light);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .navbar-sa {
            background: var(--sa-dark) !important;
            border-bottom: 3px solid var(--sa-purple);
        }

        .navbar-sa .navbar-brand {
            color: var(--sa-gold) !important;
            font-weight: 800;
            letter-spacing: 0.5px;
        }

        .navbar-sa .nav-link {
            color: rgba(255,255,255,.85) !important;
            font-weight: 500;
            transition: color .2s;
        }

        .navbar-sa .nav-link:hover,
        .navbar-sa .nav-link.active {
            color: var(--sa-gold) !important;
        }

        .sa-badge {
            background: var(--sa-purple);
            color: #fff;
            font-size: .65rem;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 20px;
            vertical-align: middle;
            margin-left: 4px;
        }

        .btn-sa {
            background: var(--sa-purple);
            color: #fff;
            font-weight: 700;
            border: none;
            border-radius: 25px;
            padding: 8px 24px;
            transition: background .2s;
        }

        .btn-sa:hover {
            background: var(--sa-purple2);
            color: #fff;
        }

        .footer-sa {
            background: var(--sa-dark2);
            color: rgba(255,255,255,.35);
            padding: 18px 0;
            margin-top: auto;
        }

        .stat-card {
            border: none;
            border-radius: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,.08);
            transition: transform .15s;
        }

        .stat-card:hover { transform: translateY(-3px); }

        main { flex: 1; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-sa shadow">
            <div class="container">
                <a class="navbar-brand" asp-controller="SuperAdmin" asp-action="Dashboard">
                    <i class="bi bi-shield-fill-check me-2"></i>SuperAdmin
                    <span class="sa-badge">ROOT</span>
                </a>

                <button class="navbar-toggler border-secondary" type="button"
                        data-bs-toggle="collapse" data-bs-target="#saNavbar"
                        aria-controls="saNavbar" aria-expanded="false" aria-label="Menü">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="saNavbar">
                    <ul class="navbar-nav me-auto gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="SuperAdmin" asp-action="Dashboard">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="SuperAdmin" asp-action="SurveyApprovals">
                                <i class="bi bi-check2-circle me-1"></i>Anket Onayları
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="SuperAdmin" asp-action="AllResults">
                                <i class="bi bi-bar-chart-line me-1"></i>Sonuçlar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="SuperAdmin" asp-action="AdminManagement">
                                <i class="bi bi-people-fill me-1"></i>Admin Yönetimi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-box-arrow-up-left me-1"></i>Siteye Dön
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-badge-fill me-1" style="color:var(--sa-gold);"></i>
                                <span style="color:var(--sa-gold);font-weight:700;">SuperAdmin</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-1"></i>Çıkış Yap
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main" class="pb-3">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()

        </main>
    </div>

    <footer class="footer-sa">
        <div class="container text-center">
            &copy; @DateTime.Now.Year — AnketOtomasyonu SuperAdmin Paneli
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
