<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Paneli</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --admin-navy:   #1B2A4A;
            --admin-navy2:  #142038;
            --admin-yellow: #F9BC00;
            --admin-light:  #f0f4f8;
        }

        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: var(--admin-light);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* NAVBAR */
        .navbar-admin {
            background: var(--admin-navy) !important;
        }

        .navbar-admin .navbar-brand {
            color: var(--admin-yellow) !important;
            font-weight: 700;
        }

        .navbar-admin .nav-link {
            color: rgba(255,255,255,.85) !important;
            font-weight: 500;
        }

        .navbar-admin .nav-link:hover {
            color: var(--admin-yellow) !important;
        }

        /* BUTTONS */
        .btn-admin {
            background: var(--admin-yellow);
            color: var(--admin-navy);
            font-weight: 700;
            border: none;
            border-radius: 25px;
            padding: 8px 24px;
        }

        .btn-admin:hover {
            background: #e0ab00;
            color: var(--admin-navy);
        }

        /* FOOTER */
        .footer-admin {
            background: var(--admin-navy2);
            color: rgba(255,255,255,.4);
            padding: 20px 0;
            margin-top: auto;
        }

        main { flex: 1; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-admin shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-controller="Admin" asp-action="Dashboard">
                    <i class="bi bi-shield-lock me-2"></i>Admin Paneli
                </a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#adminNavbar"
                        aria-controls="adminNavbar" aria-expanded="false" aria-label="Menü">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="adminNavbar">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="CreateSurvey">
                                <i class="bi bi-plus-circle me-1"></i>Yeni Anket
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-box-arrow-up-left me-1"></i>Siteye Dön
                            </a>
                        </li>
                    </ul>

                    <!-- Kullanıcı dropdown -->
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>
                                @(Context.Session.GetString("UserFullName") ?? "Admin")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-1"></i>Çıkış Yap
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main" class="pb-3">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()

        </main>
    </div>

    <footer class="footer-admin">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - AnketOtomasyonu Admin
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
