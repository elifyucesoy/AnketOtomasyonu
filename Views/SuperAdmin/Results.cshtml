@using AnketOtomasyonu.Models.DTOs
@using AnketOtomasyonu.Models.Entities
@model SurveyResultDto
@{
    ViewData["Title"] = "Anket Sonuçları - SuperAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-bar-chart me-2" style="color:#7c3aed;"></i>Sonuçlar</h2>
        <p class="text-muted mb-0">@Model.Title</p>
    </div>
    <a asp-action="AllResults" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Sonuçlara Dön
    </a>
</div>

<!-- ÖZET -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body text-center py-4">
        <h1 class="display-4 fw-bold" style="color:#7c3aed;">@Model.TotalResponses</h1>
        <p class="text-muted mb-0">Toplam Katılımcı</p>
    </div>
</div>

@if (Model.TotalResponses == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox" style="font-size:3rem;"></i>
        <p class="mt-2">Henüz yanıt yok.</p>
    </div>
}
else
{
    @if (Model.Respondents
             .Where(r => !string.IsNullOrEmpty(r.FakulteAdi))
             .GroupBy(r => r.FakulteAdi)
             .Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold"><i class="bi bi-building me-2"></i>Fakülte / Birim Dağılımı</h6>
            </div>
            <div class="card-body">
                @foreach (var f in Model.Respondents
                        .Where(r => !string.IsNullOrEmpty(r.FakulteAdi))
                        .GroupBy(r => r.FakulteAdi)
                        .Select(g => new { Label = g.Key, Count = g.Count() })
                        .OrderByDescending(x => x.Count))
                {
                    var pct = Math.Round((double)f.Count / Model.TotalResponses * 100, 1);
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small fw-semibold">@f.Label</span>
                            <span class="small text-muted">@f.Count kişi (@pct%)</span>
                        </div>
                        <div class="progress" style="height:22px; border-radius:8px;">
                            <div class="progress-bar" role="progressbar"
                                 style="width:@pct%; background:#7c3aed; font-weight:700;"
                                 aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                                @if (pct > 10) { <span>@pct%</span> }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.Respondents
             .Where(r => !string.IsNullOrEmpty(r.BolumAdi))
             .GroupBy(r => r.BolumAdi)
             .Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold"><i class="bi bi-diagram-3 me-2"></i>Bölüm Dağılımı</h6>
            </div>
            <div class="card-body">
                @foreach (var b in Model.Respondents
                        .Where(r => !string.IsNullOrEmpty(r.BolumAdi))
                        .GroupBy(r => r.BolumAdi)
                        .Select(g => new { Label = g.Key, Count = g.Count() })
                        .OrderByDescending(x => x.Count))
                {
                    var pct = Math.Round((double)b.Count / Model.TotalResponses * 100, 1);
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small fw-semibold">@b.Label</span>
                            <span class="small text-muted">@b.Count kişi (@pct%)</span>
                        </div>
                        <div class="progress" style="height:22px; border-radius:8px;">
                            <div class="progress-bar" role="progressbar"
                                 style="width:@pct%; background:#198754; font-weight:700;"
                                 aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                                @if (pct > 10) { <span>@pct%</span> }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.Respondents.Any(r => !string.IsNullOrEmpty(r.UserFullName)))
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold"><i class="bi bi-people me-2"></i>Katılımcılar</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>#</th><th>Ad Soyad</th><th>Fakülte / Birim</th><th>Bölüm</th><th>Tarih</th></tr>
                        </thead>
                        <tbody>
                            @{ var idx = 1; }
                            @foreach (var r in Model.Respondents)
                            {
                                <tr>
                                    <td>@(idx++)</td>
                                    <td>@(r.UserFullName ?? "-")</td>
                                    <td>@(r.FakulteAdi ?? "-")</td>
                                    <td>@(r.BolumAdi ?? "-")</td>
                                    <td>@r.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @foreach (var q in Model.Questions)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold">@q.QuestionText</h6>
                    <span class="badge bg-secondary">@q.AnswerCount yanıt</span>
                </div>
            </div>
            <div class="card-body">
                @if (q.QuestionType == QuestionType.OpenEnded)
                {
                    @if (q.OpenEndedAnswers.Any())
                    {
                        <div style="max-height:300px; overflow-y:auto;">
                            @foreach (var ans in q.OpenEndedAnswers)
                            {
                                <div class="border rounded p-2 mb-2 bg-light small">@ans</div>
                            }
                        </div>
                    }
                    else { <p class="text-muted small mb-0">Henüz cevap yok.</p> }
                }
                else
                {
                    @foreach (var opt in q.OptionResults)
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="small fw-semibold">@opt.OptionText</span>
                                <span class="small text-muted">@opt.Count kişi (@opt.Percentage%)</span>
                            </div>
                            <div class="progress" style="height:22px; border-radius:8px;">
                                <div class="progress-bar" role="progressbar"
                                     style="width:@opt.Percentage%; background:#7c3aed; color:#fff; font-weight:700;"
                                     aria-valuenow="@opt.Percentage" aria-valuemin="0" aria-valuemax="100">
                                    @if (opt.Percentage > 10) { <span>@opt.Percentage%</span> }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
}
