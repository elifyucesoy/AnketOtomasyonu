@using AnketOtomasyonu.Models.Entities
@model Survey
@{
    ViewData["Title"] = "Anket Önizleme";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0"><i class="bi bi-eye me-2" style="color:#0d6efd;"></i>Anket Önizleme</h2>
        <small class="text-muted">@Model.Title</small>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Paneli Dön
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 text-primary">Genel Bilgiler</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <strong>Başlık:</strong> <p>@Model.Title</p>
            </div>
            <div class="col-md-6">
                <strong>Oluşturan:</strong> <p>@Model.CreatedByName (@Model.CreatedByBirim)</p>
            </div>
            <div class="col-12">
                <strong>Açıklama:</strong> <p>@(string.IsNullOrEmpty(Model.Description) ? "-" : Model.Description)</p>
            </div>
            <div class="col-md-4">
                <strong>Durum:</strong> <span class="badge bg-secondary">@Model.Status</span>
                <span class="badge bg-info ms-1">@Model.ApprovalStatus</span>
            </div>
            <div class="col-md-4">
                <strong>Hedef Fakülteler:</strong> <p>@(string.IsNullOrEmpty(Model.TargetFaculties) ? "Tümü" : Model.TargetFaculties)</p>
            </div>
            <div class="col-md-4">
                <strong>Tür:</strong> <p>@(Model.IsAnonymous ? "Anonim" : "Giriş Gerekli")</p>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 text-primary">Sorular (@Model.Questions.Count)</h5>
    </div>
    <div class="card-body">
        @foreach (var q in Model.Questions.OrderBy(x => x.OrderIndex))
        {
            <div class="mb-4 p-3 border rounded bg-light">
                <h6><strong>Soru @q.OrderIndex:</strong> @q.Text @(q.IsRequired ? "*" : "")</h6>
                <small class="text-muted d-block mb-2">Tip: @q.Type</small>
                
                @if (q.Type == QuestionType.Likert)
                {
                    <div class="d-flex justify-content-between text-center small mt-2" style="max-width:500px;">
                        <span>Çok Kötü</span>
                        <span>Kötü</span>
                        <span>Kararsız</span>
                        <span>İyi</span>
                        <span>Çok İyi</span>
                    </div>
                }
                else if (q.Type == QuestionType.MultipleChoice)
                {
                    <ul class="list-group list-group-flush bg-transparent">
                        @foreach (var opt in q.Options.OrderBy(o => o.OrderIndex))
                        {
                            <li class="list-group-item bg-transparent py-1"><i class="bi bi-circle me-2"></i>@opt.Text</li>
                        }
                    </ul>
                }
                else
                {
                    <div class="border p-2 bg-white text-muted italic" style="min-height:60px;">Kullanıcı buraya metin girecek...</div>
                }
            </div>
        }
    </div>
</div>
