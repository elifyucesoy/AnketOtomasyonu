@{
    ViewData["Title"] = "Anket Bulunamadı";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center py-5">
        <div style="font-size:5rem;">🔍</div>
        <h2 class="fw-bold mt-3 mb-2">Anket Bulunamadı</h2>
        <p class="text-muted mb-4">
            @if (TempData["Error"] != null)
            {
                @TempData["Error"]
            }
            else
            {
                <text>Aradığınız anket bulunamadı veya artık aktif değil.</text>
            }
        </p>
    </div>
</div>
