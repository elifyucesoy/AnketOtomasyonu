@using AnketOtomasyonu.Models.ViewModels
@model SurveyIndexViewModel
@{
    ViewData["Title"] = "Anonim Anketler";
}

@section Styles {
    <style>
        .hero-banner {
            background: linear-gradient(135deg, #3A3A3A 0%, #1a1a1a 100%);
            border-radius: 16px;
            padding: 48px 40px;
            color: #fff;
            margin-bottom: 32px;
            position: relative;
            overflow: hidden;
        }

        .hero-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(249,188,0,0.15) 0%, transparent 70%);
            border-radius: 50%;
        }

        .hero-banner h1 {
            font-weight: 800;
            font-size: 2rem;
            margin-bottom: 8px;
            position: relative;
        }

        .hero-banner p {
            opacity: 0.8;
            font-size: 1.05rem;
            margin-bottom: 0;
            position: relative;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(249,188,0,0.15);
            color: #F9BC00;
            border: 1px solid rgba(249,188,0,0.3);
            padding: 6px 16px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 16px;
        }

        .survey-card {
            border: none;
            border-radius: 16px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            height: 100%;
        }

        .survey-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.12) !important;
        }

        .survey-card .card-body {
            padding: 24px;
        }

        .survey-card .card-title {
            font-weight: 700;
            font-size: 1.15rem;
            color: #1a1a1a;
            margin-bottom: 10px;
            line-height: 1.4;
        }

        .survey-card .card-text {
            color: #666;
            font-size: 0.9rem;
            line-height: 1.6;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .survey-meta {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid #f0f0f0;
        }

        .survey-meta-item {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #888;
            font-size: 0.82rem;
            font-weight: 500;
        }

        .survey-meta-item i {
            font-size: 0.9rem;
            color: #aaa;
        }

        .btn-fill-survey {
            background: linear-gradient(135deg, #F9BC00, #E0AB00);
            color: #3A3A3A;
            font-weight: 700;
            border: none;
            border-radius: 12px;
            padding: 12px 24px;
            width: 100%;
            font-size: 0.95rem;
            transition: all 0.2s ease;
            margin-top: 20px;
        }

        .btn-fill-survey:hover {
            background: linear-gradient(135deg, #E0AB00, #c99800);
            color: #3A3A3A;
            transform: scale(1.02);
        }

        .anon-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: #e8f5e9;
            color: #2e7d32;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .empty-state {
            text-align: center;
            padding: 80px 20px;
        }

        .empty-state-icon {
            width: 120px;
            height: 120px;
            background: linear-gradient(135deg, #f5f5f5, #eee);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
        }

        .empty-state-icon i {
            font-size: 3rem;
            color: #ccc;
        }

        .stats-row {
            display: flex;
            gap: 24px;
            margin-top: 20px;
            position: relative;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: rgba(255,255,255,0.7);
            font-size: 0.9rem;
        }

        .stat-item strong {
            color: #F9BC00;
            font-size: 1.2rem;
        }
    </style>
}

<!-- HERO -->
<div class="hero-banner">
    <div class="hero-badge">
        <i class="bi bi-shield-check"></i>
        Anonim & Gizli
    </div>
    <h1>Anonim Anketler</h1>
    <p>
        Kimlik bilgileriniz kaydedilmez. Aşağıdaki anketleri giriş yapmadan doldurabilirsiniz.
    </p>
    @if (Model.Surveys.Any())
    {
        <div class="stats-row">
            <div class="stat-item">
                <strong>@Model.Surveys.Count</strong> aktif anket
            </div>
            <div class="stat-item">
                <strong>@Model.Surveys.Sum(s => s.ResponseCount)</strong> toplam katılım
            </div>
        </div>
    }
</div>

@if (!Model.Surveys.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">
            <i class="bi bi-clipboard-x"></i>
        </div>
        <h4 style="color:#555;font-weight:700;">Henüz Anonim Anket Yok</h4>
        <p class="text-muted">Şu an için aktif anonim anket bulunmuyor. Daha sonra tekrar kontrol edin.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var survey in Model.Surveys)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card survey-card shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <span class="anon-badge">
                                <i class="bi bi-shield-check"></i> Anonim
                            </span>
                            <span class="badge bg-success" style="border-radius:50px;padding:5px 12px;font-weight:600;">
                                Aktif
                            </span>
                        </div>
                        <h5 class="card-title mt-2">@survey.Title</h5>
                        @if (!string.IsNullOrEmpty(survey.Description))
                        {
                            <p class="card-text">@survey.Description</p>
                        }
                        <div class="survey-meta">
                            <div class="survey-meta-item">
                                <i class="bi bi-question-circle"></i>
                                @survey.QuestionCount soru
                            </div>
                            <div class="survey-meta-item">
                                <i class="bi bi-people"></i>
                                @survey.ResponseCount katılım
                            </div>
                            <div class="survey-meta-item">
                                <i class="bi bi-calendar3"></i>
                                @survey.CreatedAt.ToString("dd MMM yyyy")
                            </div>
                        </div>
                        <div class="mt-auto">
                            <a asp-controller="SurveyResponse"
                               asp-action="Fill"
                               asp-route-id="@survey.Id"
                               class="btn btn-fill-survey">
                                <i class="bi bi-pencil-square me-2"></i>Anketi Doldur
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.IsLoggedIn)
{
    <div class="text-center mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Tüm Anketlere Dön
        </a>
    </div>
}
