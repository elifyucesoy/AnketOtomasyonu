@{
    ViewData["Title"] = "Anket Zaten Dolduruldu";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center py-5">
        <div style="font-size:5rem;">📝</div>
        <h2 class="fw-bold mt-3 mb-2">Anket Zaten Dolduruldu</h2>
        <p class="text-muted mb-4">
            @if (TempData["Error"] != null)
            {
                @TempData["Error"]
            }
            else
            {
                <text>Bu anketi daha önce doldurmuşsunuz. Her anket yalnızca bir kez doldurulabilir.</text>
            }
        </p>
    </div>
</div>
