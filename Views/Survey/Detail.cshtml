@using AnketOtomasyonu.Models.ViewModels
@using AnketOtomasyonu.Models.Entities
@model SurveyDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">@Model.Title</h2>
        <span class="badge @Model.StatusBadgeClass me-2">@Model.Status</span>
        @if (Model.IsAnonymous)
        {
            <span class="badge bg-dark me-2"><i class="bi bi-shield-check"></i> Anonim</span>
        }
        <small class="text-muted">@Model.CreatedByName | @Model.CreatedAt.ToString("dd.MM.yyyy")</small>
    </div>
    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Geri
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <h4 class="mb-0">@Model.Questions.Count</h4>
            <small class="text-muted">Soru</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <h4 class="mb-0">@Model.ResponseCount</h4>
            <small class="text-muted">Yanit</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <small class="text-muted">Hedef</small><br />
            <strong>@(string.IsNullOrEmpty(Model.TargetRoles) ? "Herkes" : Model.TargetRoles)</strong>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <small class="text-muted">Anonim</small><br />
            <strong>@(Model.IsAnonymous ? "Evet" : "Hayir")</strong>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body"><p class="mb-0">@Model.Description</p></div>
    </div>
}

@if (Model.Status == "Taslak")
{
    <form asp-controller="Survey" asp-action="Publish" asp-route-id="@Model.Id" method="post" class="mb-4">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-success" onclick="return confirm('Anket yayinlansin mi?')">
            <i class="bi bi-broadcast me-1"></i>Anketi Yayinla
        </button>
    </form>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0"><i class="bi bi-list-ol me-2"></i>Sorular</h5>
    </div>
    <div class="card-body">
        @foreach (var q in Model.Questions.OrderBy(x => x.OrderIndex))
        {
            <div class="border rounded p-3 mb-3">
                <div class="d-flex justify-content-between">
                    <h6 class="fw-bold">
                        @(q.OrderIndex + 1). @q.Text
                        @if (q.IsRequired)
                        {
                            <span class="text-danger">*</span>
                        }
                    </h6>
                    <span class="badge bg-light text-dark">@q.TypeName</span>
                </div>
                @if (q.Options.Any())
                {
                    <ul class="list-unstyled mt-2 mb-0">
                        @foreach (var o in q.Options.OrderBy(x => x.OrderIndex))
                        {
                            <li class="text-muted small">
                                <i class="bi bi-circle me-1"></i>@o.Text
                                @if (o.Value.HasValue)
                                {
                                    <span class="text-primary">(@o.Value)</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        }
    </div>
</div>