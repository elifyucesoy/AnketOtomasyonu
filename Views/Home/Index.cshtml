@using AnketOtomasyonu.Models.ViewModels
@model SurveyIndexViewModel
@{
    ViewData["Title"] = "Anketler";
}

@section Styles {
<style>
    /* ── Sayfa arka planı: lacivert ── */
    body { background: #1B2A4A !important; }
    .footer-su { background: #111e33 !important; }

    /* ── Container padding sıfırla ── */
    .container.py-4 { padding-top: 0 !important; }

    /* ── Hero bölümü ── */
    .su-hero {
        text-align: center;
        padding: 56px 20px 44px;
        color: #fff;
    }

    .su-hero-icon {
        width: 90px;
        height: 90px;
        background: var(--su-yellow);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 28px;
        font-size: 46px;
        color: #1B2A4A;
        box-shadow: 0 6px 24px rgba(249,188,0,.35);
    }

    .su-hero h1 {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 10px;
        letter-spacing: -0.5px;
    }

    .su-hero-sub {
        color: var(--su-yellow);
        font-size: 0.82rem;
        letter-spacing: 5px;
        font-weight: 700;
        text-transform: uppercase;
    }

    /* ── Anket Kartları ── */
    .survey-cards-section { padding-bottom: 64px; }

    .survey-card {
        background: #fff;
        border-radius: 20px;
        padding: 38px 22px 28px;
        text-align: center;
        box-shadow: 0 8px 30px rgba(0,0,0,.20);
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: transform .2s, box-shadow .2s;
    }

    .survey-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(0,0,0,.28);
    }

    .survey-card-icon {
        width: 76px;
        height: 76px;
        background: var(--su-yellow);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 34px;
        color: #1B2A4A;
    }

    .survey-card-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1B2A4A;
        margin-bottom: 10px;
        line-height: 1.35;
    }

    .survey-card-desc {
        font-size: 0.85rem;
        color: #888;
        flex-grow: 1;
        margin-bottom: 22px;
        line-height: 1.55;
    }

    .survey-card-meta {
        font-size: 0.75rem;
        color: #aaa;
        margin-bottom: 14px;
    }

    /* ── Ankete Başla butonu ── */
    .btn-ankete {
        background: var(--su-yellow);
        color: #1B2A4A;
        font-weight: 700;
        border: none;
        border-radius: 30px;
        padding: 11px 26px;
        font-size: 0.92rem;
        text-decoration: none;
        display: inline-block;
        transition: background .2s, transform .15s;
        width: 100%;
    }

    .btn-ankete:hover {
        background: #e0ab00;
        color: #1B2A4A;
        transform: scale(1.03);
    }

    .btn-ankete-disabled {
        background: #ddd;
        color: #999;
        border-radius: 30px;
        padding: 11px 26px;
        font-size: 0.92rem;
        width: 100%;
        display: inline-block;
        cursor: not-allowed;
    }

    /* ── Login badge ── */
    .login-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.72rem;
        color: #aaa;
        margin-bottom: 10px;
    }

    /* ── Boş durum ── */
    .empty-state {
        text-align: center;
        color: rgba(255,255,255,.55);
        padding: 80px 20px;
    }
</style>
}

<!-- ── HERO ── -->
<div class="su-hero">
    <div class="su-hero-icon">
        <i class="bi bi-mortarboard-fill"></i>
    </div>
    <h1>Selçuk Üniversitesi</h1>
    <p class="su-hero-sub">Anket Formları</p>
</div>

<!-- ── ALERTS ── -->
@if (TempData["Error"] != null)
{
    <div class="container mb-3">
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="container mb-3">
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<!-- ── KARTLAR ── -->
@{
    var iconList = new[]
    {
        "bi-building",
        "bi-bar-chart-fill",
        "bi-bank2",
        "bi-mortarboard-fill",
        "bi-people-fill",
        "bi-clipboard2-data-fill",
        "bi-briefcase-fill",
        "bi-star-fill"
    };
}

@if (!Model.Surveys.Any())
{
    <div class="empty-state">
        <i class="bi bi-clipboard-x" style="font-size:3.5rem;"></i>
        <p class="mt-3 fs-5">Henüz aktif anket bulunmuyor.</p>
    </div>
}
else
{
    <div class="container survey-cards-section">
        <div class="row g-4 justify-content-center">
            @foreach (var survey in Model.Surveys)
            {
                var icon = iconList[survey.Id % iconList.Length];
                <div class="col-sm-6 col-lg-3">
                    <div class="survey-card">

                        <div class="survey-card-icon">
                            <i class="bi @icon"></i>
                        </div>

                        <div class="survey-card-title">@survey.Title</div>

                        @if (!string.IsNullOrEmpty(survey.Description))
                        {
                            <div class="survey-card-desc">@survey.Description</div>
                        }
                        else
                        {
                            <div class="survey-card-desc">&nbsp;</div>
                        }

                        <div class="login-badge">
                            @if (survey.IsAnonymous)
                            {
                                <i class="bi bi-shield-check text-success"></i>
                                <span class="text-success">Anonim</span>
                            }
                            else
                            {
                                <i class="bi bi-lock"></i>
                                <span>Giriş Gerekli</span>
                            }
                        </div>

                        <div class="mb-2">
                            <span class="badge bg-light text-dark border" style="font-size:0.7rem;">
                                <i class="bi bi-building me-1"></i>@survey.CreatedByBirim
                            </span>
                        </div>

                        @if (survey.Status == "Aktif")
                        {
                            <a asp-controller="SurveyResponse"
                               asp-action="Fill"
                               asp-route-id="@survey.Id"
                               class="btn-ankete mb-2">
                                Ankete Başla &rarr;
                            </a>
                        }
                        
                        @if (Model.UserRole == "Admin" || Model.UserRole == "SuperAdmin")
                        {
                            var controller = Model.UserRole == "SuperAdmin" ? "SuperAdmin" : "Admin";
                            <a asp-controller="@controller" asp-action="PreviewSurvey" asp-route-id="@survey.Id" class="btn btn-sm btn-outline-info w-100 mb-1">
                                <i class="bi bi-eye"></i> Anketi Önizle
                            </a>
                        }

                        @if (survey.Status == "Taslak")
                        {
                            <span class="badge bg-warning text-dark mb-2">Taslak (Yayında Değil)</span>
                            @if (Model.UserRole == "Admin" || Model.UserRole == "SuperAdmin")
                            {
                                <a asp-controller="Admin" asp-action="EditSurvey" asp-route-id="@survey.Id" class="btn btn-sm btn-outline-secondary w-100">
                                    Düzenle
                                </a>
                            }
                        }
                        else if (survey.Status != "Aktif")
                        {
                            <span class="btn-ankete-disabled mb-2">@survey.Status</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
