@using AnketOtomasyonu.Models.ViewModels
@model SurveyIndexViewModel
@{
    ViewData["Title"] = "Anketler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Anketler</h2>
        @if (!string.IsNullOrEmpty(Model.UserFullName))
        {
            <small class="text-muted">Hoş geldiniz, <strong>@Model.UserFullName</strong> (@Model.UserRole)</small>
        }
    </div>
    @if (Model.UserRole == "Admin")
    {
        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-primary">
            <i class="bi bi-speedometer2 me-1"></i>Admin Paneli
        </a>
    }
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Surveys.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-clipboard-x" style="font-size:3rem;"></i>
        <p class="mt-3">Henüz aktif anket bulunmuyor.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var survey in Model.Surveys)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@survey.Title</h5>
                            <span class="badge @survey.StatusBadgeClass ms-2">@survey.Status</span>
                        </div>
                        @if (!string.IsNullOrEmpty(survey.Description))
                        {
                            <p class="card-text text-muted small">@survey.Description</p>
                        }
                        <div class="d-flex gap-3 text-muted small mt-2">
                            <span><i class="bi bi-question-circle me-1"></i>@survey.QuestionCount soru</span>
                            <span><i class="bi bi-people me-1"></i>@survey.ResponseCount yanıt</span>
                            @if (survey.IsAnonymous)
                            {
                                <span><i class="bi bi-shield-check me-1"></i>Anonim</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 pt-0">
                        @if (survey.Status == "Aktif")
                        {
                            <a asp-controller="SurveyResponse" asp-action="Fill" asp-route-id="@survey.Id"
                               class="btn btn-success btn-sm w-100">
                                <i class="bi bi-pencil-square me-1"></i>Anketi Doldur
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-sm w-100" disabled>
                                @survey.Status
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}